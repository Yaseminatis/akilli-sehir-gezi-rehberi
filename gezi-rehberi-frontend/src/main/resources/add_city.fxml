<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" stylesheets="@style.css" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.AddCityController">
    <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button text="← İptal" onAction="#goBack" styleClass="back-button"/>
        <Label text="Yeni Şehir Ekle" styleClass="title-text"/>
    </HBox>

    <Separator />

    <VBox spacing="15" maxWidth="500" style="-fx-background-color: white; -fx-padding: 30; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 4);">

        <Label text="Şehir Adı" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
        <TextField fx:id="nameField" promptText="Örn: Antalya" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #d1d5db; -fx-border-radius: 5;"/>

        <Label text="Ülke" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
        <TextField fx:id="countryField" promptText="Örn: Türkiye" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #d1d5db; -fx-border-radius: 5;"/>

        <Label text="Kısa Açıklama" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
        <TextArea fx:id="descArea" promptText="Şehir hakkında turistler için kısa bir bilgi..." prefRowCount="3" style="-fx-padding: 5; -fx-background-radius: 5; -fx-border-color: #d1d5db; -fx-border-radius: 5;"/>

        <Label text="Görsel Linki (URL)" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
        <TextField fx:id="imageField" promptText="https://..." style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #d1d5db; -fx-border-radius: 5;"/>

        <Label fx:id="statusLabel" text="" style="-fx-text-fill: red; -fx-font-weight: bold;"/>

        <HBox alignment="CENTER_RIGHT" style="-fx-padding: 10 0 0 0;">
            <Button text="💾 Kaydet ve Ekle" onAction="#saveCity" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 10 20; -fx-cursor: hand; -fx-background-radius: 5;"/>
        </HBox>
    </VBox>
</VBox>