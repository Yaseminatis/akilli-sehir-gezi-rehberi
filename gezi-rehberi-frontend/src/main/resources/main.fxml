<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="org.example.MainController">
    <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>
    <HBox alignment="CENTER" spacing="20">
        <Label text="Akıllı Şehir Gezi Rehberi" styleClass="title-text"/>
        <Region HBox.hgrow="ALWAYS" /> <Button text="+ Yeni Şehir Ekle" onAction="#openAddCityPage" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand; -fx-background-radius: 5;"/>
        <Button text="⭐ Favorilerim" onAction="#openFavoritesPage" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand; -fx-background-radius: 5;"/>
    </HBox>
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
        <FlowPane fx:id="cityContainer" hgap="20" vgap="20" alignment="CENTER" />
    </ScrollPane>
</VBox>