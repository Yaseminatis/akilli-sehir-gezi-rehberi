<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="TOP_CENTER" xmlns:fx="http://javafx.com/fxml/1" xmlns="http://javafx.com/javafx/21" fx:controller="org.example.MainController">
    <HBox spacing="15" alignment="CENTER_RIGHT" style="-fx-padding: 10 20; -fx-background-color: white; -fx-border-color: #e5e7eb; -fx-border-width: 0 0 1 0;">
        <Label fx:id="welcomeLabel" text="Merhaba, Misafir" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
        <Button text="🚪 Çıkış Yap" onAction="#handleLogout" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-cursor: hand; -fx-background-radius: 5;"/>
    </HBox>
    <padding><Insets top="30" right="40" bottom="30" left="40"/></padding>
    <HBox alignment="CENTER" spacing="20">
        <Label text="Akıllı Şehir Gezi Rehberi" styleClass="title-text"/>
        <Region HBox.hgrow="ALWAYS" /> <Button fx:id="addCityBtn" text="+ Yeni Şehir Ekle" onAction="#openAddCityPage" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand; -fx-background-radius: 5;"/>
        <Button text="🗺️ Planlarım" onAction="#openPlansPage" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand; -fx-background-radius: 5; -fx-padding: 5 15;"/>
        <Button text="⭐ Favorilerim" onAction="#openFavoritesPage" style="-fx-background-color: #f59e0b; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 8 15; -fx-cursor: hand; -fx-background-radius: 5;"/>
    </HBox>
    <ScrollPane fitToWidth="true" style="-fx-background-color: transparent;">
        <FlowPane fx:id="cityContainer" hgap="20" vgap="20" alignment="CENTER" />
    </ScrollPane>
</VBox>