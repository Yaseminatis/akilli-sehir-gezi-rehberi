<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>
<?import javafx.collections.FXCollections?>
<?import java.lang.String?>

<VBox spacing="20" style="-fx-background-color: #f9fafb;" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.AdminController">
    <padding><Insets top="20" right="30" bottom="20" left="30"/></padding>

    <HBox alignment="CENTER_LEFT" spacing="20">
        <Button text="⬅ Ana Sayfaya Dön" onAction="#goBack" style="-fx-background-color: #6b7280; -fx-text-fill: white; -fx-cursor: hand;"/>
        <Label text="👑 Yönetim Paneli" style="-fx-font-size: 28px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
    </HBox>
    <Separator/>

    <TabPane tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS" style="-fx-background-color: transparent;">

        <Tab text="Şehir Yönetimi">
            <HBox spacing="20" style="-fx-padding: 20;">

                <VBox spacing="10" prefWidth="280">
                    <Label text="Kayıtlı Şehirler" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <ListView fx:id="cityListView" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5;"/>
                    <Button text="➕ Yeni Şehir Ekle (Formu Temizle)" onAction="#clearCityForm" maxWidth="Infinity" style="-fx-background-color: #4b5563; -fx-text-fill: white; -fx-cursor: hand;"/>
                </VBox>

                <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <Label text="Şehir Detayları" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label fx:id="cityMessageLabel" style="-fx-font-weight: bold;"/>

                    <TextField fx:id="cityNameField" promptText="Şehir Adı"/>
                    <TextField fx:id="cityCountryField" promptText="Ülke"/>
                    <TextField fx:id="cityImageField" promptText="Görsel URL"/>
                    <TextArea fx:id="cityDescArea" promptText="Açıklama..." prefRowCount="5" wrapText="true"/>

                    <HBox spacing="10">
                        <Button fx:id="btnSaveCity" text="Kaydet" onAction="#saveCity" prefWidth="100" style="-fx-background-color: #10b981; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Button fx:id="btnUpdateCity" text="Güncelle" onAction="#updateCity" disable="true" prefWidth="100" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Button fx:id="btnDeleteCity" text="Sil" onAction="#deleteCity" disable="true" prefWidth="100" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </HBox>
        </Tab>

        <Tab text="Mekan Yönetimi">
            <HBox spacing="20" style="-fx-padding: 20;">

                <VBox spacing="10" prefWidth="280">
                    <Label text="Kayıtlı Mekanlar" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
                    <ListView fx:id="placeListView" VBox.vgrow="ALWAYS" style="-fx-background-radius: 5;"/>
                    <Button text="➕ Yeni Mekan Ekle (Formu Temizle)" onAction="#clearPlaceForm" maxWidth="Infinity" style="-fx-background-color: #4b5563; -fx-text-fill: white; -fx-cursor: hand;"/>
                </VBox>

                <VBox spacing="15" HBox.hgrow="ALWAYS" style="-fx-background-color: white; -fx-padding: 25; -fx-background-radius: 10; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5);">
                    <Label text="Mekan Detayları" style="-fx-font-size: 18px; -fx-font-weight: bold;"/>
                    <Label fx:id="placeMessageLabel" style="-fx-font-weight: bold;"/>

                    <TextField fx:id="placeNameField" promptText="Mekan Adı"/>
                    <HBox spacing="15">
                        <ComboBox fx:id="placeCategoryBox" promptText="Kategori Seçin" HBox.hgrow="ALWAYS" maxWidth="Infinity">
                            <items>
                                <FXCollections fx:factory="observableArrayList">
                                    <String fx:value="MUSEUM"/>
                                    <String fx:value="PARK"/>
                                    <String fx:value="HISTORICAL_SITE"/>
                                    <String fx:value="RESTAURANT"/>
                                    <String fx:value="CAFE"/>
                                </FXCollections>
                            </items>
                        </ComboBox>
                        <ComboBox fx:id="placeCityBox" promptText="Hangi Şehirde?" HBox.hgrow="ALWAYS" maxWidth="Infinity"/>
                    </HBox>
                    <TextArea fx:id="placeDescArea" promptText="Açıklama..." prefRowCount="5" wrapText="true"/>

                    <HBox spacing="10">
                        <Button fx:id="btnSavePlace" text="Kaydet" onAction="#savePlace" prefWidth="100" style="-fx-background-color: #8b5cf6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Button fx:id="btnUpdatePlace" text="Güncelle" onAction="#updatePlace" disable="true" prefWidth="100" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                        <Button fx:id="btnDeletePlace" text="Sil" onAction="#deletePlace" disable="true" prefWidth="100" style="-fx-background-color: #ef4444; -fx-text-fill: white; -fx-font-weight: bold; -fx-cursor: hand;"/>
                    </HBox>
                </VBox>
            </HBox>
        </Tab>

    </TabPane>
</VBox>