<?xml version="1.0" encoding="UTF-8"?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.control.*?>
<?import javafx.geometry.Insets?>

<VBox spacing="20" alignment="CENTER" stylesheets="@style.css" xmlns:fx="http://javafx.com/fxml/1" fx:controller="org.example.LoginController" style="-fx-background-color: #f3f4f6;">
    <padding><Insets top="40" right="60" bottom="40" left="60"/></padding>

    <VBox spacing="15" alignment="CENTER" maxWidth="400" style="-fx-background-color: white; -fx-padding: 40; -fx-background-radius: 15; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 15, 0, 0, 5);">
        <Label text="🌍 Akıllı Gezi Rehberi" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #111827;"/>
        <Label text="Keşfetmeye başlamak için giriş yapın" style="-fx-text-fill: #6b7280; -fx-font-size: 14px;"/>

        <Separator style="-fx-padding: 10 0;"/>

        <VBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Kullanıcı Email:" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
            <TextField fx:id="emailField" promptText="Örn: user@akillisehir.com" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #d1d5db; -fx-border-radius: 5;"/>
        </VBox>
        <VBox spacing="5" alignment="CENTER_LEFT">
            <Label text="Şifre:" style="-fx-font-weight: bold; -fx-text-fill: #374151;"/>
            <PasswordField fx:id="passwordField" promptText="******" style="-fx-padding: 10; -fx-background-radius: 5; -fx-border-color: #d1d5db; -fx-border-radius: 5;"/>
        </VBox>

        <Label fx:id="errorLabel" text="" style="-fx-text-fill: red; -fx-font-size: 12px;"/>

        <Button text="🚀 Giriş Yap ve Keşfet" onAction="#login" style="-fx-background-color: #3b82f6; -fx-text-fill: white; -fx-font-weight: bold; -fx-padding: 12 20; -fx-cursor: hand; -fx-background-radius: 8; -fx-pref-width: 320;"/>
    </VBox>
</VBox>